<nav>
  <p>
    <a href="/home">
      <i class="fa-solid fa-graduation-cap"></i>THE DYNAMIC
      <span>VISION</span>
    </a>
  </p>
  <div class="info">
    <% if(currUser){ %>
    <a href="/dashboard"
      ><i class="fa-solid fa-chart-line"></i>
      <h4>Dashboard</h4></a
    >
    <a href="/students"
      ><i class="fa-solid fa-user-group"></i>
      <h4>All Students</h4></a
    >
    <a href="/fund"
      ><i class="fa-solid fa-wallet"></i>
      <h4>Fund</h4></a
    >
    <div class="profile" title="Account settings" role="button">
      <img
          src="https://ui-avatars.com/api/?name=<%=currUser.username%>&bold=true&background=31312f&color=f3efea"
          alt="Img"
        />
    </div>
    <%}%>
    <% if(!currUser){ %>
    <a class="nav-link active login-out" aria-current="page" href="/signup"
      ><i class="fa-solid fa-user-plus"></i><h4>Signup</h4></a
    >
    <a href="/login"><i class="fa-solid fa-right-to-bracket"></i><h4>Login</h4></a>
    <%}%>
  </div>
</nav>
<div class="menu hide">
  <ul>
    <li><i class="fa-solid fa-user"></i>
      <% if(!currUser){ %>
        <span>User</span>
      <%}else{%>
        <span><%=currUser.username%></span>
      <%}%></li>
    <a href="/logout"><li><i class="fa-solid fa-right-to-bracket"></i><span>Logout</span></li></a>
  </ul>
</div>
<div><%- include("../includes/flash.ejs") %></div>
<script>
  const click = document.querySelector(".profile img");
  const menu = document.querySelector(".menu");
  click.addEventListener("click", function () {
    menu.classList.toggle("hide");
  });
</script>