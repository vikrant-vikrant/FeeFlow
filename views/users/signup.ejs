<% layout('/layouts/boilerPlate') -%>
<link rel="stylesheet" href="css/signLogin.css" />
<div>
  <div class="main">
    <%- include('../includes/navbar')%>
    <div class="container">
      <form action="/signup" method="post" class="form">
        <p class="login">Signup</p>
        <label>
          <input
            class="input"
            type="text"
            placeholder=""
            required
            id="username"
            name="username"
          />
          <span>Username</span>
        </label>
        <label>
          <input
            class="input"
            type="email"
            placeholder=""
            required
            id="email"
            name="email"
          />
          <span>Email</span>
        </label>
        <label>
          <input
            type="password"
            class="input"
            placeholder=""
            required=""
            id="password"
            name="password"
          />
          <span>Password</span>
        </label>
        <button class="submit">Create Account</button>
        <div class="signup">
          Already Have an account?
          <a href="/login">Login</a>
        </div>
        <div class="divider"></div>
      </form>
    </div>
  </div>
</div>
