<% layout('layouts/boilerPlate') -%>
<link rel="stylesheet" href="/css/newStudent.css" />
<body>
  <div class="main">
    <div class="container">
      <img src="/img/addStudent.jpg" alt="Student reading a book" />
      <form action="/students/newStudent" method="post" class="form">
        <p class="title">Register</p>
        <p class="message">
          <i class="fa-solid fa-user-plus"></i>&nbsp;&nbsp;Add a new student
        </p>
        <label>
          <input
            class="input"
            type="text"
            placeholder=""
            required=""
            id="name"
            name="name"
          />
          <span>Name</span>
        </label>
        <div class="flex">
          <label>
            <% const grades =
            ["0","1st","2nd","3rd","4th","5th","6th","7th","8th","9th","10th","11th","12th"];
            %>
            <select name="grade" id="grade" required>
              <option value="" selected disabled>Grade</option>
              <% grades.forEach(g => { %>
              <option value="<%= g %>"><%= g %></option>
              <% }) %>
            </select>
          </label>
          <label>
            <input
              class="input"
              type="number"
              placeholder=""
              required=""
              id="fees"
              name="fees"
            />
            <span>Fees</span>
          </label>
          <label>
            <input
              class="input"
              type="number"
              placeholder=""
              required=""
              id="dueFees"
              name="dueFees"
              value="<%=0%>"
            />
            <span>Due fees</span>
          </label>
        </div>
        <label>
          <input
            type="date"
            class="input"
            placeholder=""
            required=""
            id="joiningDate"
            name="joiningDate"
            value="<%=todayDate%>"
          />
          <span>Joining Date</span>
        </label>
        <label>
          <input
            class="input"
            type="text"
            placeholder=""
            id="parent"
            name="parent"
          />
          <span>Parent</span>
        </label>
        <label>
          <input
            class="input"
            type="number"
            placeholder=""
            id="contact"
            name="contact"
          />
          <span>Contact</span>
        </label>
        <label>
          <input
            class="input"
            type="number"
            placeholder=""
            id="phone"
            name="phone"
          />
          <span>Phone</span>
        </label>
        <label>
          <input
            class="input"
            type="text"
            placeholder=""
            id="note"
            name="note"
          />
          <span>Note</span>
        </label>

        <button class="submit">Add Student</button>
      </form>
    </div>
  </div>
</body>
<script src="/js/newStudent.js"></script>
